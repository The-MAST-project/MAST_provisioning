<?xml version="1.0" encoding="utf-8"?>
<WindowsCustomizations xmlns="http://schemas.microsoft.com/Windows/11/Customizations" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
  <PackageConfig xmlns="urn:schemas-microsoft-com:windows-provisioning:v2">
    <ID>{12345678-1234-1234-1234-123456789012}</ID>
    <Name>MAST Provisioning</Name>
    <Version>1.0.0.0</Version>
    <ProvisioningType>Offline</ProvisioningType>
    <Owner>MAST</Owner>
    <IsDynamic>false</IsDynamic>
    <Description>Provisions MAST Observatory software components</Description>
  </PackageConfig>

  <Settings xmlns="http://schemas.microsoft.com/Windows/11/Customizations">
    <Customizations>
      <DeviceCustomizations>
        <DeviceCompletionCommands>
          <Command wcm:action="add">
            <Order>1</Order>
            <CommandLine>powershell.exe -ExecutionPolicy Bypass -NoProfile -File "Z:\%COMPUTERNAME%\execute-mast-provisioning.ps1"</CommandLine>
          </Command>
        </DeviceCompletionCommands>
      </DeviceCustomizations>
    </Customizations>
  </Settings>
</WindowsCustomizations>
