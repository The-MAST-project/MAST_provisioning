# Upstream now ships a stripped (no-indexes) astrometry.tgz under the cygwin provider,
# so it is checked in rather than ignored. Keep this commented marker as a reminder
# that the full ~30GB asset (with indexes) is not what lives in the repo.
# server/providers/cygwin/assets/astrometry.tgz
.venv/
venv/
__pycache__/
server/providers/mast/assets/mast_github.txt
.claude/

# vm/run-prov-test.py session logs are local debug artifacts -- do not commit.
vm/run-logs/*.log
